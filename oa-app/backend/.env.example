# 环境变量配置
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oa_app
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 办公室位置（用于打卡校验）
OFFICE_LATITUDE=31.2304
OFFICE_LONGITUDE=121.4737
CHECK_IN_RADIUS=100
